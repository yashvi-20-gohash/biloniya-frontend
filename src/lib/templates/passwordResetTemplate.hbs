<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Verify Your Email with OTP</title>
  </head>
  <body
    style='margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f8faf8; color: #1a2e1a;'
  >
    <table role='presentation' style='width: 100%; border-collapse: collapse;'>
      <tr>
        <td align='center' style='padding: 40px 0;'>
          <table
            role='presentation'
            style='width: 600px; border-collapse: collapse; background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);'
          >
            <tr>
              <td
                style='padding: 40px 30px; text-align: center; background-color: #b0191e; border-radius: 8px 8px 0 0;'
              >
                <img
                  src='{{LOGO}}'
                  alt='Logo'
                  style='width: 100px; margin-bottom: 10px;'
                />
                <h1 style='color: #ffffff; font-size: 28px; margin: 0;'>Verify
                  Your Email</h1>
              </td>
            </tr>
            <tr>
              <td style='padding: 40px 30px;'>
                <p
                  style='font-size: 16px; line-height: 1.5; margin: 0 0 20px;'
                >Hello,</p>
                <p
                  style='font-size: 16px; line-height: 1.5; margin: 0 0 20px;'
                >Thank you for signing up! To complete your registration, please
                  use the following One-Time Password (OTP) to verify your email
                  address:</p>
                <table
                  role='presentation'
                  style='width: 100%; border-collapse: collapse;'
                >
                  <tr>
                    <td align='center' style='padding: 20px 0;'>
                      <div
                        style='background-color: #f1f8f1; border: 2px solid #b0191e; border-radius: 8px; padding: 20px; font-size: 32px; font-weight: bold; letter-spacing: 8px; color: #b0191e;'
                      >
                        {{OTP}}
                      </div>
                    </td>
                  </tr>
                </table>
                <p
                  style='font-size: 16px; line-height: 1.5; margin: 20px 0 0;'
                >This OTP is valid for 10 minutes. Please enter this code on the
                  verification page to confirm your email address.</p>
                <p
                  style='font-size: 16px; line-height: 1.5; margin: 20px 0 0;'
                >If you didn't request this verification, please ignore this
                  email or contact our support team if you have any concerns.</p>
              </td>
            </tr>
            <tr>
              <td style='padding: 30px; text-align: center; color: #7a8c7a;'>
                <p style='margin: 0 0 10px; font-size: 14px;'>&copy; 2025
                  info@biloniya.com. All rights reserved.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>